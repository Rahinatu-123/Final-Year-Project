rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - user can only upload their own
    match /profile_photos/{userId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Style photos - user can only upload their own
    match /style_photos/{userId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Allow authenticated users to upload style images
    match /styles/{tailorId}/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.auth.uid == tailorId;
      allow delete: if request.auth != null && request.auth.uid == tailorId;
    }

    // Chat audio messages
    match /chats/{chatId}/audio/{filename} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
