rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - comprehensive permissions
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      
      // Following subcollection
      match /following/{followingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Followers subcollection - Allow any authenticated user to add themselves
      match /followers/{followerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == followerId;
        allow update: if request.auth != null && request.auth.uid == followerId;
        allow delete: if request.auth != null && (request.auth.uid == followerId || request.auth.uid == userId);
      }
      
      // Connections subcollection (user's following list)
      match /connections/{connectionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Shop Orders subcollection - for orders placed by/for this user
      match /shop_orders/{orderId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // All other subcollections
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Business collection (for tailor business profiles)
    match /business/{businessId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
      
      // All subcollections
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
    }

    // Tailors collection
    match /tailors/{tailorId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == tailorId;
      allow update: if request.auth != null && request.auth.uid == tailorId;
      allow delete: if request.auth != null && request.auth.uid == tailorId;
      
      // All subcollections
      match /{document=**} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == tailorId;
      }
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null; // Allow any authenticated user to like/comment
      allow delete: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Comments subcollection
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == resource.data.authorId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }

    // Orders collection
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Chats collection
    match /chats/{chatId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // Styles collection
    match /styles/{styleId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Fabrics collection
    match /fabrics/{fabricId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Products collection (Shop items from tailors and fabric sellers)
    match /products/{productId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.sellerId;
      allow update: if request.auth != null && request.auth.uid == resource.data.sellerId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // Shop Orders collection - for shop product orders
    match /shop_orders/{orderId} {
      allow read: if request.auth != null && 
        (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.tailorId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.customerId;
      allow update: if request.auth != null && 
        (request.auth.uid == resource.data.customerId || request.auth.uid == resource.data.tailorId);
      allow delete: if request.auth != null && request.auth.uid == resource.data.customerId;
    }

    // Fabric Orders collection - in-chat fabric orders between seller and client
    match /fabric_orders/{orderId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.clientId);
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.sellerId || request.auth.uid == request.resource.data.clientId);
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.clientId);
      allow delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // Group Orders collection - collaborative ordering system
    match /group_orders/{groupId} {
      // Read: any authenticated user can browse all groups
      allow read: if request.auth != null;
      
      // Create: any authenticated user can create groups
      allow create: if request.auth != null;
      
      // Update: authenticated users can join/update groups.
      allow update: if request.auth != null;
      
      // Only creator can delete
      allow delete: if request.auth != null && resource.data.createdById == request.auth.uid;
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == resource.data.senderId;
        allow delete: if request.auth != null && request.auth.uid == resource.data.senderId;
      }
    }

    // Custom Orders collection - for tailors' manually added clients
    match /custom_orders/{customOrderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.tailorId;
      allow update: if request.auth != null && resource.data.tailorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.tailorId == request.auth.uid;
    }

    // Tailor's Clients collection - simplified client profiles
    match /tailor_clients/{tailorId} {
      // Allow parent document operations (needed for subcollection access)
      allow read, write: if false;
      
      // Clients subcollection
      match /clients/{clientId} {
        allow read: if request.auth != null && request.auth.uid == tailorId;
        allow create: if request.auth != null && request.auth.uid == tailorId;
        allow update: if request.auth != null && request.auth.uid == tailorId;
        allow delete: if request.auth != null && request.auth.uid == tailorId;
      }
    }

    // Tailor portfolio collection (image + description items)
    match /tailor_portfolio/{itemId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.tailorId == request.auth.uid;
      allow update: if request.auth != null && resource.data.tailorId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.tailorId == request.auth.uid;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
